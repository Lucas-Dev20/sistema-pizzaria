<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="950.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ufersa.poo.pizzaria.controllers.GerenciarPizzaController">

    <!-- MENU LATERAL ESQUERDO COM SÍMBOLOS E MÉTODOS DE NAVEGAÇÃO -->
    <left>
        <VBox prefWidth="200.0" spacing="10" styleClass="sidebar">
            <ImageView fitWidth="180.0" preserveRatio="true">
                <image>
                    <Image url="@../images/logo.png" />
                </image>
            <VBox.margin>
               <Insets top="-40.0" />
            </VBox.margin>
            </ImageView>
         <Button minHeight="-Infinity" mnemonicParsing="false" onAction="#irPainel" text="⚙ Painel de Controle">
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass>
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor></Button>

            <Button alignment="CENTER" minHeight="-Infinity" onAction="#irPedidos" text="📋 Pedidos" VBox.vgrow="ALWAYS">
                <styleClass>
                    <String fx:value="sidebar-btn" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass></Button>

            <Button minHeight="-Infinity" onAction="#irClientes" text="👥 Clientes">
                <styleClass>
                    <String fx:value="sidebar-btn" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass></Button>

            <Button minHeight="-Infinity" onAction="#irTiposPizza" text="🍕 Tipos de pizza">
                <styleClass>
                    <String fx:value="sidebar-btn-active" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass></Button>

            <Button minHeight="-Infinity" onAction="#irAdicionais" text="💼 Adicionais">
                <styleClass>
                    <String fx:value="sidebar-btn" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass></Button>

            <Button minHeight="-Infinity" onAction="#irEstoque" text="📦 Estoque">
                <styleClass>
                    <String fx:value="sidebar-btn" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass></Button>

            <Button minHeight="-Infinity" onAction="#irRelatorios" text="📊 Relatórios">
                <styleClass>
                    <String fx:value="sidebar-btn" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass></Button>


            <Button minHeight="-Infinity" onAction="#irFuncionarios" text="👤 Funcionários">
                <styleClass>
                    <String fx:value="sidebar-btn" />
                    <String fx:value="dashboard-menu-item-border" />
                </styleClass>
            </Button>

            <Region prefHeight="250.0" prefWidth="170.0" styleClass="dashboard-menu-item-border" stylesheets="@../css/style.css" VBox.vgrow="ALWAYS" />

            <Button onAction="#sair" styleClass="sidebar-btn-exit" text="🚪 Sair" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #F4F4F4;">

            <VBox style="-fx-padding: 20;" styleClass="header-banner">
                <Label style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;" text="Tipos de pizza" />
                <Label fx:id="lblTipoUsuario" style="-fx-text-fill: white; -fx-font-size: 14;" text="" />
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;" styleClass="content-card" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="20">
                    <TextField fx:id="txtBusca" promptText="Buscar sabor..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnNovoSabor" onAction="#handleNovoSabor" text="+ Novo Sabor" />
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 5;" VBox.vgrow="ALWAYS">
                    <TilePane fx:id="containerPizzas" hgap="20" prefColumns="2" style="-fx-background-color: white;" vgap="20" />
                </ScrollPane>

            </VBox>
        </VBox>
    </center>
</BorderPane>
