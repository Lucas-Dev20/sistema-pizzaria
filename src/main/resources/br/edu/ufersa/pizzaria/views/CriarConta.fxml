<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="650.0" styleClass="background" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ufersa.poo.pizzaria.controllers.CriarContaController">

    <VBox alignment="CENTER" prefHeight="500.0" prefWidth="540.0" spacing="15" AnchorPane.bottomAnchor="237.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="80.0" AnchorPane.topAnchor="50.0">

        <Pane minHeight="509.0" prefHeight="509.0" prefWidth="520.0" styleClass="login-card">

            <VBox layoutX="30" layoutY="30" prefWidth="400" spacing="15">

                <Label styleClass="titulo" text="Criar conta" />

                <Label text="Nome:" />

                <TextField fx:id="txtNome" promptText="João Silva" styleClass="campo" />

                <Label text="Email:" />

                <TextField fx:id="txtEmail" promptText="joaosilva@email.com" styleClass="campo" />

                <Label text="Senha" />

                <PasswordField fx:id="txtSenha" promptText="Digite a senha" styleClass="campo" />

                <Label text="Confirmar senha" />

                <PasswordField fx:id="txtConfirmarSenha" promptText="Digite a senha" styleClass="campo" />

                <HBox alignment="CENTER" spacing="40">

                    <Button onAction="#cancelar" styleClass="botao" text="Cancelar" />

                    <Button onAction="#avancar" styleClass="botao" text="Avançar" />

                </HBox>

            </VBox>

        </Pane>

    </VBox>

</AnchorPane>
