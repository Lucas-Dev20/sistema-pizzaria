<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="700.0"
            styleClass="background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ufersa.poo.pizzaria.controllers.CriarContaController">

    <VBox alignment="CENTER"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <Pane styleClass="login-card" maxWidth="550">

            <VBox layoutX="30" layoutY="25" prefWidth="490" spacing="15">

                <Label styleClass="titulo" text="Criar conta"/>

                <Label text="Nome:"/>
                <TextField fx:id="txtNome" promptText="João Silva" styleClass="campo"/>

                <Label text="Email:"/>
                <TextField fx:id="txtEmail" promptText="joaosilva@email.com" styleClass="campo"/>

                <Label text="Senha"/>
                <PasswordField fx:id="txtSenha" promptText="Digite a senha" styleClass="campo"/>

                <Label text="Confirmar senha"/>
                <PasswordField fx:id="txtConfirmarSenha" promptText="Digite a senha" styleClass="campo"/>

                <HBox alignment="CENTER" spacing="40">
                    <Button onAction="#cancelar" styleClass="botao" text="Cancelar"/>
                    <Button onAction="#avancar" styleClass="botao-primary" text="Avançar"/>
                </HBox>

            </VBox>

        </Pane>

    </VBox>

</AnchorPane>
