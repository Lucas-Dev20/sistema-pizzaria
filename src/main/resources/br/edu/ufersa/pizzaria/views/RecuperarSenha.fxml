<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0"
            prefWidth="700.0"
            stylesheets="@../css/style.css"
            styleClass="background"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ufersa.poo.pizzaria.controllers.RecuperarSenhaController">

    <VBox alignment="CENTER"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <Pane styleClass="login-card" maxWidth="550">

            <VBox spacing="20"
                  layoutX="40"
                  layoutY="40"
                  prefWidth="460">

                <Label text="Recuperar Senha" styleClass="titulo"/>

                <Label text="Digite seu email de recuperação:"/>

                <TextField fx:id="txtEmail"
                           promptText="joaosilva@email.com"
                           styleClass="campo"/>

                <HBox alignment="CENTER" spacing="25">
                    <Button text="Cancelar"
                            styleClass="botao"
                            onAction="#voltarLogin"/>
                    <Button text="Recuperar Senha"
                            styleClass="botao-primary"
                            onAction="#recuperarSenha"/>
                </HBox>

            </VBox>

        </Pane>

    </VBox>

</AnchorPane>
