<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane prefHeight="700.0" prefWidth="950.0"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ufersa.poo.pizzaria.controllers.GerenciarAdicionaisController">

    <!-- MENU LATERAL ESQUERDO COM SÍMBOLS E METODOS DE NAVEGAÇÃO -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="10">
            <ImageView fitWidth="150" preserveRatio="true" style="-fx-padding: 0 0 20 0;">
                <image>
                    <Image url="@../images/logo.png"/>
                </image>
            </ImageView>

            <Button text="📋 Pedidos" styleClass="sidebar-btn" onAction="#irPedidos"/>

            <Button text="👥 Clientes" styleClass="sidebar-btn" onAction="#irClientes"/>

            <Button text="🍕 Tipos de pizza" styleClass="sidebar-btn" onAction="#irTiposPizza"/>

            <Button text="💼 Adicionais" styleClass="sidebar-btn-active" onAction="#irAdicionais"/>

            <Button text="📦 Estoque" styleClass="sidebar-btn" onAction="#irEstoque"/>

            <Button text="📊 Relatórios" styleClass="sidebar-btn" onAction="#irRelatorios"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="🚪 Sair" styleClass="sidebar-btn-exit" onAction="#sair"/>
        </VBox>
    </left>

    <!-- CONTEÚDO PRINCIPAL -->
    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #F4F4F4;">

            <!-- CABEÇALHO-->
            <VBox styleClass="header-banner" style="-fx-padding: 25 20 25 20;">
                <Label text="Adicionais" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
            </VBox>

            <!-- CARD BRANCO PRINCIPAL -->
            <VBox styleClass="content-card" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;" VBox.vgrow="ALWAYS" spacing="15">

                <!-- Barra de Busca e Botão Novo Adicional -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <TextField fx:id="txtBusca" promptText="Buscar adicional..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnNovoAdicional" text="+ Novo Adicional" onAction="#handleNovoAdicional" styleClass="btn-success"/>
                </HBox>

                <!-- TABELA DE ADICIONAIS CONFORME O FIGMA -->
                <TableView fx:id="tabelaAdicionais" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="250"/>
                        <TableColumn fx:id="colPreco" text="Valor" prefWidth="150"/>
                        <TableColumn fx:id="colEstoque" text="Estoque" prefWidth="150"/>
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="150" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

            </VBox>
        </VBox>
    </center>
</BorderPane>