<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="950.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ufersa.poo.pizzaria.controllers.GerenciarAdicionaisController">

    <!-- MENU LATERAL ESQUERDO COM SÍMBOLS E METODOS DE NAVEGAÇÃO -->
    <left>
        <VBox prefWidth="200" spacing="10" styleClass="sidebar">
            <ImageView fitWidth="180.0" preserveRatio="true" style="-fx-padding: 0 0 20 0;">
                <image>
                    <Image url="@../images/logo.png" />
                </image>
            </ImageView>
         <Button mnemonicParsing="false" onAction="#irPainel" text="⚙ Painel de Controle">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass>
         </Button>

            <Button onAction="#irPedidos" text="📋 Pedidos">
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass></Button>

            <Button onAction="#irClientes" text="👥 Clientes">
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass></Button>

            <Button onAction="#irTiposPizza" text="🍕 Tipos de Pizza">
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass></Button>

            <Button onAction="#irAdicionais" text="💼 Adicionais">
            <styleClass>
               <String fx:value="sidebar-btn-active" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass></Button>

            <Button onAction="#irEstoque" text="📦 Estoque">
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass></Button>

            <Button onAction="#irRelatorios" text="📊 Relatórios">
            <styleClass>
               <String fx:value="sidebar-btn" />
               <String fx:value="dashboard-menu-item-border" />
            </styleClass></Button>

            <Button onAction="#irFuncionarios" text="👤 Funcionários">
            <styleClass>
               <String fx:value="dashboard-menu-item-border" />
               <String fx:value="sidebar-btn" />
            </styleClass>
            </Button>


            <Region styleClass="dashboard-menu-item-border" VBox.vgrow="ALWAYS" />

            <Button onAction="#sair" styleClass="sidebar-btn-exit" text="🚪 Sair" />
         <BorderPane.margin>
            <Insets top="-40.0" />
         </BorderPane.margin>
        </VBox>
    </left>

    <!-- CONTEÚDO PRINCIPAL -->
    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #F4F4F4;">

            <!-- CABEÇALHO-->
            <VBox style="-fx-padding: 25 20 25 20;" styleClass="header-banner">
                <Label style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;" text="Adicionais" />
            </VBox>

            <!-- CARD BRANCO PRINCIPAL -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;" styleClass="content-card" VBox.vgrow="ALWAYS">

                <!-- Barra de Busca e Botão Novo Adicional -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <TextField fx:id="txtBusca" promptText="Buscar adicional..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnNovoAdicional" onAction="#handleNovoAdicional" styleClass="btn-success" text="+ Novo Adicional" />
                </HBox>

                <!-- TABELA DE ADICIONAIS CONFORME O FIGMA -->
                <TableView fx:id="tabelaAdicionais" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" prefWidth="250" text="Nome" />
                        <TableColumn fx:id="colPreco" prefWidth="150" text="Valor" />
                        <TableColumn fx:id="colEstoque" prefWidth="150" text="Estoque" />
                        <TableColumn fx:id="colAcoes" prefWidth="150" style="-fx-alignment: CENTER;" text="Ações" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </VBox>
        </VBox>
    </center>
</BorderPane>
